APP_HOST=0.0.0.0
APP_PORT=8080

DATABASE_URL=postgresql+asyncpg://grafinder:grafinder@postgres:5432/grafinder

GRAFANA_API_URL=http://grafana:3000
GRAFANA_PUBLIC_URL=http://localhost:3001
GRAFANA_PORT=3001
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=grafinder_admin
GRAFANA_DATASOURCE_UID=grafinder-postgres

SEARCH_RESULT_LIMIT=8
MAX_DOCUMENTS_PER_TASK=5
CRAWL_TIMEOUT_SECONDS=45
CRAWL_MAX_MARKDOWN_CHARS=12000
LLM_REQUIRED=true
AUTO_OPEN_BROWSER=false

LLM_PROVIDERS_FILE=config/llm_providers.example.json

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-your-doubao-endpoint
DOUBAO_API_KEY=

CUSTOM_LLM_BASE_URL=https://your-llm-endpoint.example.com/v1
CUSTOM_LLM_MODEL=your-model-name
CUSTOM_LLM_API_KEY=
